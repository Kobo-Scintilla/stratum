#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/cioky/Projects/app/node_modules/.pnpm/just-bash@3.0.1/node_modules/just-bash/node_modules:/home/cioky/Projects/app/node_modules/.pnpm/just-bash@3.0.1/node_modules:/home/cioky/Projects/app/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/cioky/Projects/app/node_modules/.pnpm/just-bash@3.0.1/node_modules/just-bash/node_modules:/home/cioky/Projects/app/node_modules/.pnpm/just-bash@3.0.1/node_modules:/home/cioky/Projects/app/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../just-bash/dist/bin/shell/shell.js" "$@"
else
  exec node  "$basedir/../../../../just-bash/dist/bin/shell/shell.js" "$@"
fi
