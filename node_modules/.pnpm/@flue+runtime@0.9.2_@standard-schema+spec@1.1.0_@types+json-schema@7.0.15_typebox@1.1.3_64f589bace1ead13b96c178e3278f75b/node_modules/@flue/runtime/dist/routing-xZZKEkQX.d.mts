import { Hono } from "hono";

//#region src/runtime/admin-app.d.ts
/**
 * Creates a mountable Hono sub-app for read-only deployment inspection.
 * Mount it explicitly beneath an application-chosen prefix and protect that
 * mount with application-owned authorization.
 *
 * The mounted sub-app exposes:
 *
 * - `GET /openapi.json`
 * - `GET /agents`
 * - `GET /runs`
 * - `GET /runs/:runId`
 */
declare function admin(): Hono;
//#endregion
//#region src/routing.d.ts
/**
 * Structural contract for the default export of an authored `app.ts` entry.
 * Any object exposing a compatible `fetch()` method satisfies it, including a
 * `new Hono()` instance.
 *
 * On Cloudflare, `env` contains bindings and `ctx` is the
 * `ExecutionContext`. On Node, `env` contains Hono's Node adapter bindings for
 * the incoming and outgoing messages, and `ctx` is `undefined`.
 */
interface Fetchable {
  fetch(request: Request, env?: unknown, ctx?: unknown): Response | Promise<Response>;
}
//#endregion
export { admin as n, Fetchable as t };