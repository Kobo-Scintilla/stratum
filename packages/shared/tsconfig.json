{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"experimentalDecorators": true,
		"useDefineForClassFields": false,
		"skipLibCheck": true,
		"declaration": true,
		"sourceMap": true,
		"outDir": "dist"
	},
	"include": ["src/**/*.ts"]
}
