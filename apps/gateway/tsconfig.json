{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"experimentalDecorators": true,
		"useDefineForClassFields": false,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"outDir": "dist",
		"rootDir": "src",
		"sourceMap": true
	},
	"include": ["src/**/*.ts"]
}
