{
    "name": "@stratum/app",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "check": "bun run check:errors && bun run check:lint",
        "check:svelte": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings 2>&1",
        "check:errors": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json 2>&1 | grep -E \"^[0-9]+ ERROR|Cannot find|is not defined|has no exported\" || true",
        "check:lint": "cd ../.. && biome check apps/frontend/src 2>&1 || true",
        "check:full": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json 2>&1",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
    },
    "dependencies": {
        "@hugeicons/core-free-icons": "^4.2.0",
        "@hugeicons/svelte": "^1.1.2",
        "@stratum/shared": "workspace:*",
        "formsnap": "^2.0.1",
        "marked": "^18.0.5",
        "prismjs": "^1.30.0",
        "remult": "^3.3.12",
        "runed": "^0.37.1",
        "svelte-persisted-state": "^1.4.1",
        "svelte-sonner": "^1.1.1",
        "sveltekit-superforms": "^2.30.1",
        "zod": "3"
    },
    "devDependencies": {
        "@fontsource-variable/outfit": "^5.2.8",
        "@internationalized/date": "^3.12.2",
        "@sveltejs/adapter-node": "^5.5.4",
        "@sveltejs/kit": "^2.62.0",
        "@sveltejs/vite-plugin-svelte": "^7.0.0",
        "@tailwindcss/vite": "^4.2.2",
        "@types/node": "^25.9.1",
        "@types/prismjs": "^1.26.6",
        "bits-ui": "^2.18.1",
        "clsx": "^2.1.1",
        "fallow": "^2.88.1",
        "mode-watcher": "^1.1.0",
        "prettier": "^3.8.1",
        "prettier-plugin-svelte": "^3.5.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "remixicon-svelte": "^0.0.5",
        "shadcn-svelte": "^1.3.0",
        "svelte": "^5.55.2",
        "svelte-check": "^4.4.6",
        "tailwind-merge": "^3.6.0",
        "tailwind-variants": "^3.2.2",
        "tailwindcss": "^4.2.2",
        "tw-animate-css": "^1.4.0",
        "typescript": "^6.0.2",
        "vaul-svelte": "^1.0.0-next.7",
        "vite": "^8.0.7"
    }
}
